# Copy to .env and fill in values (never commit .env)

NUXT_SITE_URL=https://ukpubs.co.uk
NUXT_PUBLIC_APP_URL=https://ukpubs.co.uk
NUXT_PUBLIC_API_URL=https://ukpubs.co.uk
BASE_URL=https://ukpubs.co.uk

# Supabase Postgres — REQUIRED on Netlify
# Use the Transaction pooler (port 6543) for serverless / Prisma runtime:
#   Dashboard → Project Settings → Database → Connection string → Transaction pooler
# Example:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# Optional: Session pooler or direct URL (port 5432) for local prisma migrate only:
# DIRECT_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Mapbox public token (required for venue maps and /map)
NUXT_PUBLIC_MAPBOX_TOKEN=

# Google Maps (optional — maps UI)
NUXT_PUBLIC_GOOGLE_MAPS_KEY=

# Google Places API (New) — for scripts/enrich_venue_features.py (features, description, --photos)
# county hub cards (scripts/enrich_county_images.ts), town/stadium cards (scripts/enrich_town_images.py, enrich_stadium_images.py)
# Enable "Places API (New)" in Google Cloud Console
GOOGLE_PLACES_API_KEY=

# Skiddle Events API — town-wide UK listings (default --source skiddle)
SKIDDLE_API_KEY=

# Eventbrite — events from YOUR organization(s) only (--source eventbrite)
# Private token: Account Settings → API Keys → Show tokens → Private token
EVENTBRITE_PRIVATE_TOKEN=
EVENTBRITE_ORGANIZATION_ID=
# OAuth app credentials (not used for direct API calls):
# Application_Key=
# OAuth_Client_Secret=

# User id stored on imported events (defaults to ADMIN_EMAIL)
ENRICH_EVENTS_USER_ID=
# Default town for scripts/enrich_venue_events.py (optional — avoids passing --town each run)
ENRICH_EVENTS_TOWN=Brighton

SUPABASE_URL=
SUPABASE_KEY=
ADMIN_EMAIL=
USER_NAME=
EVENT_IMG_FOLDER=
VENUE_IMG_FOLDER=

# Stripe — pub claim subscriptions (use test keys locally; live keys on Netlify only)
# Dashboard → Developers → API keys. Prefer a restricted key (rk_) in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Recurring monthly prices (GBP). Billing anchored to the 1st of each month in Checkout.
# Solo: 1 pub | Group: up to 5 | Regional: up to 25 | Enterprise: 25+ (custom limit in app)
STRIPE_PRICE_SOLO=
STRIPE_PRICE_GROUP=
STRIPE_PRICE_REGIONAL=
STRIPE_PRICE_ENTERPRISE=